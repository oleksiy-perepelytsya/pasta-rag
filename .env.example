# Telegram
TELEGRAM_BOT_TOKEN=

# LLM — at least one key required; others are optional
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default model (auto-detected by prefix: gemini-* | claude-* | gpt-* | o1/o3/o4*)
DEFAULT_LLM_MODEL=gemini-2.0-flash

# MongoDB
# Use service name 'mongodb' when running via Docker Compose, 'localhost' for local dev
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=pasta_rag

# ChromaDB
# Use service name 'chromadb' when running via Docker Compose, 'localhost' for local dev
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Session behaviour
SESSION_TIMEOUT_MINUTES=30   # Inactivity before session is vectorized
MAX_CONTEXT_MESSAGES=50      # Max messages from current session sent to LLM
MAX_RAG_RESULTS=3            # Chunks returned per RAG query

# Logging
LOG_LEVEL=INFO
